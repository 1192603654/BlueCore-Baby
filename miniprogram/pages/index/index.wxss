/* 顶部宝宝滚动栏 */
.baby-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 40rpx;
}

.baby-list {
  display: flex;
  padding: 10rpx 0;
}

.baby-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
  opacity: 0.6;
  transition: all 0.3s;
}

.baby-item.active {
  opacity: 1;
  transform: scale(1.1);
}

.avatar, .avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
}

.baby-item.active .avatar {
  border-color: var(--brand-blue);
}

.avatar-placeholder {
  background-color: #EAEAEA;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #999;
}

.name {
  margin-top: 10rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #555;
}

/* 状态卡片区域 */
.status-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.status-card {
  display: flex;
  flex-direction: column;
  padding: 40rpx;
  color: #333;
}

/* 颜色分类卡片样式 */
.feed-card {
  background-color: #F0F8FF; /* 淡淡的蓝底 */
  border-left: 8rpx solid var(--brand-blue);
}
.feed-card .value { color: var(--brand-blue); }

.diaper-card {
  background-color: #FFFDF5; /* 淡淡的黄底 */
  border-left: 8rpx solid var(--brand-yellow);
}
.diaper-card .value { color: #D4A346; } /* 深一点的黄色适配文字 */

.sleep-card {
  background-color: #FFF5F7; /* 淡淡的粉底 */
  border-left: 8rpx solid var(--brand-pink);
}
.sleep-card .value { color: #D68D84; } /* 深一点的粉色适配文字 */


.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
}

.time {
  font-size: 24rpx;
  color: #888;
}

.card-body {
  display: flex;
  align-items: baseline;
  gap: 15rpx;
}

.value {
  font-size: 48rpx;
  font-weight: bold;
}

.sub-type {
  font-size: 28rpx;
  color: #666;
}

/* 广告预留区域 */
.ad-container {
  margin-top: 40rpx;
  padding-top: 20rpx;
}

.mock-ad {
  width: 100%;
  height: 200rpx;
  background-color: #E8E8E8;
  border-radius: var(--card-radius);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 28rpx;
}
