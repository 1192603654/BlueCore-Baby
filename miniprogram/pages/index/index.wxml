<view class="container">
  <!-- 顶部：横向滚动的宝宝头像切换栏 -->
  <scroll-view scroll-x class="baby-scroll" enable-flex>
    <view class="baby-list">
      <view class="baby-item {{item.id === currentBabyId ? 'active' : ''}}"
            wx:for="{{babies}}"
            wx:key="id"
            bindtap="switchBaby"
            data-id="{{item.id}}">
        <image class="avatar" src="{{item.avatar || '/images/default_baby.png'}}" mode="aspectFill"></image>
        <text class="name">{{item.name}}</text>
      </view>
      <view class="baby-item add-baby" bindtap="addBaby">
        <view class="avatar-placeholder">+</view>
        <text class="name">添加宝宝</text>
      </view>
    </view>
  </scroll-view>

  <!-- 中部：喂养、尿布、睡眠的“最近状态”大卡片 -->
  <view class="status-section">
    <!-- 喂养卡片 -->
    <view class="card status-card feed-card" bindtap="recordFeed">
      <view class="card-header">
        <view class="title-wrap">
            <text class="title">喂养 🍼</text>
            <text class="time">{{lastFeed.time || '暂无记录'}}</text>
        </view>
        <text class="view-all" catchtap="goToHistory" data-type="feed">记录 ></text>
      </view>
      <view class="card-body">
        <text class="value">{{lastFeed.value !== null && lastFeed.value !== undefined ? lastFeed.value + ' ' + lastFeed.unit : '点击记录'}}</text>
        <text class="sub-type">{{lastFeed.sub_type || ''}}</text>
      </view>
    </view>

    <!-- 尿布卡片 -->
    <view class="card status-card diaper-card" bindtap="recordDiaper">
      <view class="card-header">
        <view class="title-wrap">
            <text class="title">尿布 🧻</text>
            <text class="time">{{lastDiaper.time || '暂无记录'}}</text>
        </view>
        <text class="view-all" catchtap="goToHistory" data-type="diaper">记录 ></text>
      </view>
      <view class="card-body">
        <text class="value">{{lastDiaper.sub_type ? lastDiaper.sub_type : '点击记录'}}</text>
      </view>
    </view>

    <!-- 睡眠卡片 -->
    <view class="card status-card sleep-card" bindtap="recordSleep">
      <view class="card-header">
        <view class="title-wrap">
            <text class="title">睡眠 🌙</text>
            <text class="time">{{lastSleep.time || '暂无记录'}}</text>
        </view>
        <text class="view-all" catchtap="goToHistory" data-type="sleep">记录 ></text>
      </view>
      <view class="card-body">
        <text class="value">{{lastSleep.duration ? lastSleep.duration : '点击记录'}}</text>
      </view>
    </view>

    <!-- 疫苗卡片 -->
    <view class="card status-card vaccine-card" bindtap="recordVaccine">
      <view class="card-header">
        <view class="title-wrap">
            <text class="title">疫苗 💉</text>
            <text class="time">{{lastVaccine.date || '暂无记录'}}</text>
        </view>
        <text class="view-all" catchtap="goToHistory" data-type="vaccine">记录 ></text>
      </view>
      <view class="card-body">
        <text class="value">{{lastVaccine.sub_type ? lastVaccine.sub_type : '点击记录'}}</text>
      </view>
    </view>
  </view>

  <!-- 右下角悬浮统计按钮 -->
  <view class="fab-btn" bindtap="goToStats">
    <text>📊 统计</text>
  </view>

  <!-- 底部：预留 ad 广告组件位 -->
  <view class="ad-container" wx:if="{{showAd}}">
    <!-- 这里放置官方广告组件，暂时模拟展示 -->
    <view class="mock-ad">
      <text>广告预留位</text>
    </view>
  </view>
</view>
