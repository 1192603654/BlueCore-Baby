.page-bg {
  background-color: #F8F5F2; /* 奶油背景色 */
  min-height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
}

.form-card {
  background-color: #FFFFFF;
  border-radius: 36rpx;
  padding: 50rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.03);
}

.form-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1A2F4C;
  margin-bottom: 50rpx;
  text-align: center;
}

.form-group {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 90rpx; /* 增加固定高度 */
  padding: 0 30rpx; /* 调整内边距，解决被截断问题 */
  background-color: #F8F9FA;
  border-radius: 20rpx; /* 更圆润的边角 */
  font-size: 34rpx; /* 稍微调大字体 */
  color: #333;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.quick-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.tag {
  padding: 12rpx 28rpx;
  background-color: #F0F6FC;
  color: #8EB2D6;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.2s;
  border: 2rpx solid transparent;
}

.tag.active {
  background-color: #8EB2D6;
  color: #FFF;
  border-color: #8EB2D6;
}

.radio-group {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.radio-label {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  color: #333;
}

.radio-label radio {
  transform: scale(0.9);
  margin-right: 16rpx;
}

.btn-submit {
  width: 100%;
  padding: 30rpx;
  background-color: #4A90E2; /* 深蓝色，视觉更醒目 */
  color: #FFF;
  border-radius: 100rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  margin-top: 60rpx;
  box-shadow: 0 10rpx 20rpx rgba(74, 144, 226, 0.3);
}
.btn-submit:active {
  transform: scale(0.98);
}
